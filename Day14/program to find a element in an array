#include<stdio.h>
void main()
{
	int n,i,j;
	printf("Enter the number of element: ");
	scanf("%d",&n);
	int a[n];
	printf("Enter the element of arrays:\n ");
	for(i=0;i<n;i++)
	{
		scanf("%d",&a[i]);
	}
	// printing the original array
	printf("The arrays is\n ");
	for(i=0;i<n;i++)
	{
		printf("%d\t",a[i]);
	}
	int count =0,num;
	for(i=0;i<n;i++)
	{
		for(j=i+1;j<n;j++)
		{
			if(a[i]==a[j])
			{
				num = a[i];
				count ++;
			}
		}
	}
	
	printf("count:%d",count);
	
}
