#include<stdio.h>
int  main()
{
	int n,i,even =0,odd= 0;
	printf("Enter the no of element: ");
	scanf("%d",&n);
	int a[n];
	printf("Enter the arrays element: ");
	for(i=0;i<n;i++)
	{
		scanf("%d",a[i]);
	}
	for(i=0;i<n;i++)
	{
		printf("%d",a[i]);
	}
	
	for(i=0;i<n;i++)
	{
		if(a[i]%2==0)
		{
			printf("Even number are:%d\n",a[i]);
			even++;
		}
     }
     for(i=0;i<n;i++)
     {
     	if(a[i]%2!=0)
     	{
		  printf("odd number are:%d\n",a[i]);
		  odd++;
		 }
	 }
	 
	printf("Even count%d\n",even);
	printf("Odd count%d\n",odd);
	
	
}
