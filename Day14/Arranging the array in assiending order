#include<stdio.h>
void main()
{
	int i,n,temp,j;
	printf("Enter the no of element: ");
	scanf("%d",&n);
	int a [n];
	// input the Array
	printf("Enter the elements of array: ");
	for(i=0;i<n;i++)
	{
		scanf("%d",&a[i]);
	}
	// Original array 
	printf("the Original  of array \n ");
	for(i=0;i<n;i++)
	{
		printf("%d\t",a[i]);
	}
	//loop for sort an array
	for(i=0;i<n;i++)
	{
		for(j=i+1;j<n;j++)
		{
			if(a[i]>a[j])
			{
				temp = a[i];
				a[i]= a[j];
				a[j]= temp;
			}
		}
	}
	//print Reverse array
	printf("the Sorted of array \n ");
	for(i=0;i<n;i++)
	{
		printf("%d\t",a[i]);
	}
	
}
