Check whether a number is prime or not.

#include<stdio.h>
void main()
{
	int num,i,sum =0;
	printf("Enter the number: ");
	scanf("%d",&num);
	for (i=1;i<=num;i++)
	{
		if(num%i==0)
		{
			printf("the factor : %d\n",i);
			sum= sum+1;
		}}
		if(sum==2)
		{
			printf("the number is prime number.");
		}
		else
		{
			printf("the number is not a prime number.");
		}
	
}
