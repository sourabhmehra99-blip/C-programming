#include<stdio.h>
void main()
{
	long long int rem,sum=0,a,n;
	printf("Enter the three dight number: ");
	scanf("%d",&n);
	a = n;
	while(n>0)
	{
		rem = n%10;
		sum = sum + (rem*rem*rem);
		n= n/10;
	}
	if(a==sum)
	{
		printf("the number is armstrong.");
	}
	else
	{
		printf("the number is not armstrong");
	}
}
