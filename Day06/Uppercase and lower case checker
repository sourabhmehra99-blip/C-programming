 Write a program to check whether a character is uppercase or lowercase.
#include<stdio.h>
void main()
{
	char letter;
	printf("Enter the letter: ");
	scanf("%c",&letter);
	if (letter >= 65 && letter <= 'Z')
	{
		printf("letter is in upper case");
	}
	else
	{
		if (letter >= 'a' && letter <='z') {
		
		printf("the letter is in lower case");}
		
		else{
			printf("the letter is not in upper case or lower case");
		}
	}
}
