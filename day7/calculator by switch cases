//switch case : calculater
#include<stdio.h>
void  main()
{
	char ch;
	float a,b;
	printf("-------------------\n");
	printf("press + for additon\n");
	printf("press - for substraction\n");
	printf("press * for multiple\n");
	printf("press / for division\n");
	printf("-------------------\n");
	printf("Enter your choice:\n");
	scanf("%c",&ch);
	switch (ch)
	{
		case '+':
			printf("Enter the value of a and b:\n");
			scanf("%f%f",&a,&b);
			printf("sum = %f\n",a +b);
			break;
		case '-':
			printf("Enter the value of a and b:\n");
			scanf("%f%f",&a,&b);
			printf("diff = %f\n",a - b);
				break;
		case '*':
			printf("Enter the value of a and b:\n");
			scanf("%f%f",&a,&b);
			printf("multiply = %f\n",a*b);
				break;
		case '/':
			printf("Enter the value of a and b:\n");
			scanf("%f%f",&a,&b);
			printf("divide = %f\n",a /b);
				break;
		default:
			printf("invlaid statement.\n");
				break;
	}
	
}
