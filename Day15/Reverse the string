// program to reverse the string
#include<stdio.h>
int main()
{
	int n,i;
	//printf("Enter the elements of string: ");
	//scanf("%d",&n);
	printf("Enter the string : ");
	
	char str[20];
	//scanf("%s",str); // not work in case of string
	gets(str);
	puts(str);
	int len =0;
	while(str[len]!='\0')
	{
		len++;
	}
	char temp[20];
    for(i=0;i<len;i++)
    {
    	temp[i]= str[len-i-1];
	}
	puts(temp);
}
