#include<stdio.h>
int main()
{   int n;

    printf("Enter number of strings: ");
    scanf("%d",&n);
    getchar();   

    char str[n];
	
	printf("Enter the string : ");
	gets(str);
	puts(str);
	
	int len =0;
	while(str[len]!='\0')
	{
		len++;
	}
	int i;
	for(i=0;i<len;i++)
	{
		if(str[i]== ' ')
		{
			continue;
		}
		
		else {
		
		  str[i] = str[i]+32;}
	} 
	printf("%s",str);
	
}
