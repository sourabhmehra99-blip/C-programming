// program to find the length of string without function
#include<stdio.h>
int main()
{
	
	char str[20];
	printf("Enter the string : ");
	
	//scanf("%s",str); // not work in case of string
	gets(str);
	puts(str);
	int len =0;
	while(str[len]!='\0')
	{
		len++;
	}
	printf("length of the string : %d",len);
}
