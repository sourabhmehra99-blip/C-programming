// program to sort a String 
#include<stdio.h>
int main()
{
	int n,i,j;
	printf("Enter the element of string: ");
	scanf("%d",&n);
	
	getchar();
	
	char str[n];
	
	printf("Enter the first sting:");
	gets(str);
	
	printf("the first string:\t ");
	puts(str);
	
	int len =0;
	while(str[len] != 0)
	{
		len++;
	}
	char temp;
	for(i=0;i<len;i++)
	{
		for(j=i+1;j<len;j++)
		{
			if(str[i]>str[j])
			{
				temp = str[i];
				str[i]= str[j];
				str[j]= temp;
			}
		}
	}
	printf("Sorted string: ");
	puts(str);

}
