//Program the to copy a string to another 
#include<stdio.h>
int main()
{
	int n,i;
	printf("Enter the number of element: ");
	scanf("%d",&n);
	getchar();
	
	char str[n];
	printf("Enter the string: ");
	gets(str);
	printf("the original string: ");
	puts(str);
	int len=0;
	for(i=0;i<n;i++)
	{
		if(str[i]!='\0')
		{
			len++;
		}
	}
	char copy[n];
	for(i=0;i<len;i++)
	{
		copy[i]=str[i];
	}
	printf("the copy string:");
	puts(copy);
}
