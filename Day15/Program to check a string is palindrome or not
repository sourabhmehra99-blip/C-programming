// program to check a given string is palindrome or not
#include<stdio.h>
int main()
{
	
	int n,i;
	printf("Enter the number of string: ");// taking input for elements for string
	scanf("%d",&n);
	
	
	getchar();//
	
	char temp,str[n];
	char pal[n];
	gets(pal);
	printf("string\n");
	
	puts(pal);
	
	int len=0;
	for(i=0;i<n;i++)
	{
		if(pal[i]=='\0')
		{
			break;
		}
		len++;
	}
	for(i=0;i<len;i++)
	{
		str[i]=pal[len-1-i];

	}
	printf("New string\n");
	puts(str);
	if(str==pal)
	{
		printf("the string is palindrome\n");
	}
	else
	{
		printf("Not a palindrome");
	}
}
