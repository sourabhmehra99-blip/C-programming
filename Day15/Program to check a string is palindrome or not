// program to check a given string is palindrome or not
#include<stdio.h>
int main()
{
	
	int n,i;
	printf("Enter the number of string: ");// taking input for elements for string
	scanf("%d",&n);
	
	
	getchar();//
	
	int flag =1;
	char str[n];
	char pal[n];
	printf("Enter the sring: ");
	gets(pal);
	printf("Original string:\t");
	
	puts(pal);
	
	int len=0;
	for(i=0;i<n;i++)
	{
		if(pal[i]=='\0')
		{
			break;
		}
		len++;
	}
	for(i=0;i<len;i++)
	{
		str[i]=pal[len-1-i];

	}
	printf("New string:\t");
	puts(str);
	for(i=0;i<len;i++)
	{
		if(str[i]!=pal[i])
		{
			flag = 0;
			break;
		}
	}
	if(flag ==1)
	{
		printf("palindrome");
	}
	else
	printf("NOT a palindrome");

}
