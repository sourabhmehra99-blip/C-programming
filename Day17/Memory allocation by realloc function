#include<stdio.h>
#include<stdlib.h>
void main()
{
	int n,*ptr,i;
	printf("Enter the no of elements: ");
	scanf("%d",&n);
	ptr =malloc(n*sizeof(int));
	if(ptr==NULL)
	{
		printf("Error in memory allocation!!!");
		exit(0);
		//return;
	}
	printf("Enter the elements: ");
	for(i=0;i<n;i++)
	{
		scanf("%d",(ptr+i));
	}
	printf("Enter the new no of elements: ");
	scanf("%d",&n);
	int *ptr1;
	ptr1=realloc (ptr,n*sizeof(int));
	printf("Enter the new elements: ");
		for(i=0;i<n;i++)
	{
		scanf("%d",(ptr1+i));
	}
	
	printf("display the elements of array: ");
	for(i=0;i<n;i++)
	{
		printf("%d\t",*(ptr1+i));
	}
	free(*ptr1);
}
