// write a program to add two matric
#include<stdio.h>
void main()
{
	int r,c,j,i;
	printf("Enter the size of r and c: ");
	scanf("%d%d",&r,&c);
	int a[r][c],b[r][c],sum[r][c];
	printf("Enter the elements of 2-D array\n");
	
	for(i=0;i<r;i++)
	{
		for(j=0;j<c;j++)
		{
			scanf("%d",&a[i][j]);
		}
	}
	
	printf("\nDisplay the elements of 2-D array A \n");
	
	for(i=0;i<r;i++)
	{
		for(j=0;j<c;j++)
		{
			printf("%d\t",a[i][j]);
		}
		printf("\n");
	}
	
	printf("Enter the elements of 2-D array B\n");
	
	for(i=0;i<r;i++)
	{
		for(j=0;j<c;j++)
		{
			scanf("%d",&b[i][j]);
		}
	}
	
	printf("\nDisplay the elements of 2-D array B\n");
	
	for(i=0;i<r;i++)
	{
		for(j=0;j<c;j++)
		{
			printf("%d\t",b[i][j]);
		}
		printf("\n");
    }
	
	//loop to add a matrix
	for(i=0;i<r;i++)
	{
		for(j=0;j<c;j++)
		{
			sum[i][j]= a[i][j]+b[i][j];
		}
	}
	printf("\nDisplay the sum elements of 2-D array sum \n");
	
	for(i=0;i<r;i++)
	{
		for(j=0;j<c;j++)
		{
			printf("%d\t",sum[i][j]);
		}
		printf("\n");
    }	
}
