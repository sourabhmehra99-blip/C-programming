// write a program to the sum of digonal elements of matrix.
#include<stdio.h>
void main()
{
	int r,c,j,i,sum = 0;
	printf("Enter the size of r and c: ");
	scanf("%d%d",&r,&c);
	int a[r][c];
	if(r==c)
	{
	
	printf("Enter the elements of 2-D array\n");
	
	for(i=0;i<r;i++)
	{
		for(j=0;j<c;j++)
		{
			scanf("%d",&a[i][j]);
		}
	}
	
	printf("Display the elements of 2-D array\n");
	
	for(i=0;i<r;i++)
	{
		for(j=0;j<c;j++)
		{
			printf("%d\t",a[i][j]);
			if(i==j)
			{
				sum = sum +a[i][j];
			}
		}
		printf("\n");
		
	}
	printf("the sum of digonal elements : %d",sum);
	}
	else
	   printf("Invalid matrix");
}
