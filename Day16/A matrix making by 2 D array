// making the matric by 2-D ARRAYS: 
/*#include<stdio.h>
void main()
{
	int r,c,j,i;
	printf("Enter the size of r and c: ");
	scanf("%d%d",&r,&c);
	int a[r][c];
	printf("Enter the elements of 2-D array\n");
	
	for(i=0;i<r;i++)
	{
		for(j=0;j<c;j++)
		{
			scanf("%d",&a[i][j]);
		}
	}
	
	printf("Display the elements of 2-D array\n");
	
	for(i=0;i<r;i++)
	{
		for(j=0;j<c;j++)
		{
			printf("%d\t",a[i][j]);
		}
		printf("\n");
	}
}
