#include<stdio.h>
void main()
{
	int r,c,j,i,k;
	printf("Enter the size of r and c: ");
	scanf("%d%d",&r,&c);
	int a[r][c],b[r][c],mul[r][c];
	printf("Enter the elements of 2-D array\n");
	
	for(i=0;i<r;i++)
	{
		for(j=0;j<c;j++)
		{
			scanf("%d",&a[i][j]);
		}
	}
	
	printf("\nDisplay the elements of 2-D array A \n");
	
	for(i=0;i<r;i++)
	{
		for(j=0;j<c;j++)
		{
			printf("%d\t",a[i][j]);
		}
		printf("\n");
	}
	
	printf("Enter the elements of 2-D array B\n");
	
	for(i=0;i<r;i++)
	{
		for(j=0;j<c;j++)
		{
			scanf("%d",&b[i][j]);
		}
	}
	
	printf("\nDisplay the elements of 2-D array B\n");
	
	for(i=0;i<r;i++)
	{
		for(j=0;j<c;j++)
		{
			printf("%d\t",b[i][j]);
		}
		printf("\n");
    }
	// loop for multiplication of 2 matrix
	for(i=0;i<r;i++)
	{
		for(j=0;j<c;j++)
		{
			mul[i][j]= 0;
			for(k=0;k<c;k++)
			{
				mul[i][j]= mul[i][j]+a[i][k]*b[k][j];
			}
			
		}
	}
		for(i=0;i<r;i++)
	{
		for(j=0;j<c;j++)
		{
			printf("%d\t",mul[i][j]);
		}
		printf("\n");
	}

}
