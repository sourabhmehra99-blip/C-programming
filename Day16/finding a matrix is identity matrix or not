#include<stdio.h>

int main()
{
    int r,c,j,i,flag=1;

    printf("Enter the size of r and c: ");
    scanf("%d%d",&r,&c);

    int a[r][c];

    printf("Enter the elements of 2-D array\n");

    for(i=0;i<r;i++)
    {
        for(j=0;j<c;j++)
        {
            scanf("%d",&a[i][j]);
        }
    }

    printf("\nDisplay the elements of 2-D array A\n");

    for(i=0;i<r;i++)
    {
        for(j=0;j<c;j++)
        {
            printf("%d\t",a[i][j]);
        }
        printf("\n");
    }


    if(r != c)
    {
        printf("Not an identity matrix");
        return 0;
    }


    for(i=0;i<r && flag;i++)
    {
        for(j=0;j<c;j++)
        {
            if(i==j && a[i][j]!=1)
            {
                flag=0;
                break;
            }

            else if(i!=j && a[i][j]!=0)
            {
                flag=0;
                break;
            }
        }
    }


    if(flag==1)
    {
        printf("Identity matrix");
    }
    else
    {
        printf("Not an identity matrix");
    }

    return 0;
}
