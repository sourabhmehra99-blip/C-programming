// structure in C

#include<stdio.h>
struct emp
{
    int eid ;
	char name[20];
	float sal;	
};
void main()
{
	struct emp e1;
	printf("Enter the details of emplyoyee\n");
	printf("Enter the eid: ");
	scanf("%d",&e1.eid);
	printf("Enter the  name of emplyoyee: ");
	scanf("%s",&e1.name);
	printf("Enter the salary: ");
	scanf("%.2 f",&e1.sal);
	
	printf("Display the details of emplyoyee\n");
	printf("eid = %d\n",e1.eid);
	printf("name = %s\n",e1.name);
	printf("salary = %f\n",e1.sal);
}
